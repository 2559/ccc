page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.card {
  background-color: #ffffff;
  border-radius: 8rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.status-waiting {
  background-color: #fa8c16;
}

.status-producing {
  background-color: #1890ff;
}

.status-completed {
  background-color: #52c41a;
}

.status-shipped {
  background-color: #8c8c8c;
}

.btn {
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
  margin: 10rpx 0;
}

.btn-primary {
  background-color: #52c41a;
  color: #ffffff;
}

.btn-start {
  background-color: #52c41a;
  color: #ffffff;
}

.btn-finish {
  background-color: #1890ff;
  color: #ffffff;
}

.btn-ship {
  background-color: #fa8c16;
  color: #ffffff;
}

.btn-disabled {
  background-color: #d9d9d9;
  color: #999999;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.timeline {
  padding: 20rpx 0;
}

.timeline-item {
  position: relative;
  padding-left: 40rpx;
  padding-bottom: 40rpx;
  border-left: 2rpx solid #e8e8e8;
  margin-left: 10rpx;
}

.timeline-item:last-child {
  border-left: none;
}

.timeline-dot {
  position: absolute;
  left: -8rpx;
  top: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #1890ff;
  border: 2rpx solid #ffffff;
}

.timeline-item:last-child .timeline-dot {
  background-color: #52c41a;
}

.timeline-time {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.timeline-status {
  font-size: 28rpx;
  color: #333333;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
  text-align: right;
}

.filter-tabs {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.filter-tab.active {
  color: #1890ff;
  font-weight: bold;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1890ff;
  border-radius: 2rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 28rpx;
}
